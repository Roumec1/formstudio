<!DOCTYPE html>
<html lang="cs">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Forma Studio — CNC, 3D tisk, Laser · Šumperk</title>
<meta name="description" content="Proměníme váš soubor v hotový výrobek. Velkoformátové CNC frézování, 100W laser, 3D tisková farma. Komplexní projekty vítány, série od 1 kusu.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:ital,wght@0,300;0,400;0,500;0,600;1,400&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#faf9f7; --white:#fff; --ink:#111110; --mid:#65635e;
  --light:#ede9e1; --border:#e0dbd2;
  --accent:#c94e1e; --soft:#e8824f; --abg:#fdf2ec; --abdr:#f0c4ae;
  --serif:'Instrument Serif',Georgia,serif;
  --sans:'Inter',system-ui,sans-serif;
}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--ink);font-family:var(--sans);font-weight:400;line-height:1.6;overflow-x:hidden;-webkit-font-smoothing:antialiased}

/* ─── NAV ─── */
nav{position:sticky;top:0;z-index:200;background:rgba(250,249,247,.97);backdrop-filter:blur(16px);border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;padding:0 3rem;height:64px}
.logo{font-family:var(--serif);font-size:1.4rem;color:var(--ink);text-decoration:none;letter-spacing:-.02em}
.logo b{color:var(--accent);font-weight:400}
.nav-links{display:flex;gap:2rem;list-style:none}
.nav-links a{font-size:.78rem;color:var(--mid);text-decoration:none;transition:color .2s}
.nav-links a:hover{color:var(--ink)}
.nav-r{display:flex;align-items:center;gap:1.2rem}
.lsw{display:flex;align-items:center}
.lbtn{background:none;border:none;cursor:pointer;font-family:var(--sans);font-size:.72rem;font-weight:500;color:var(--mid);padding:.2rem .45rem;letter-spacing:.05em;transition:color .2s}
.lbtn.on{color:var(--accent)}
.lsep{color:var(--border);font-size:.8rem;user-select:none}
.cta-nav{background:var(--ink);color:white;font-size:.76rem;font-weight:500;padding:.55rem 1.35rem;text-decoration:none;border-radius:2px;transition:background .2s,transform .15s;white-space:nowrap}
.cta-nav:hover{background:var(--accent);transform:translateY(-1px)}

/* ─── HERO ─── */
#hero{display:grid;grid-template-columns:1fr 1fr;min-height:calc(90vh - 64px)}
.hl{display:flex;flex-direction:column;justify-content:center;padding:5rem 3.5rem 5rem 3rem}
.hero-tag{display:inline-flex;align-items:center;gap:.45rem;background:var(--abg);border:1px solid var(--abdr);color:var(--accent);font-size:.69rem;font-weight:500;letter-spacing:.05em;padding:.28rem .8rem;border-radius:20px;margin-bottom:1.6rem;width:fit-content}
.hero-tag::before{content:"✦";font-size:.55rem}
h1{font-family:var(--serif);font-size:clamp(2.9rem,5vw,5.2rem);line-height:1.03;letter-spacing:-.035em;margin-bottom:1.4rem;font-weight:400}
h1 em{font-style:italic;color:var(--accent)}
.hero-sub{font-size:.97rem;color:var(--mid);line-height:1.85;max-width:440px;margin-bottom:.65rem;font-weight:300}
.hero-sub strong{color:var(--ink);font-weight:500}
.hero-proof{font-size:.78rem;color:var(--mid);margin-bottom:2.1rem;font-style:italic}
.hero-proof strong{color:var(--ink);font-style:normal;font-weight:500}
.hero-btns{display:flex;gap:.8rem;align-items:center;flex-wrap:wrap;margin-bottom:1.3rem}
.btn{display:inline-flex;align-items:center;gap:.4rem;text-decoration:none;border-radius:2px;font-family:var(--sans);font-size:.8rem;font-weight:500;transition:background .2s,color .2s,border-color .2s,transform .15s;cursor:pointer;border:none;line-height:1}
.btn:hover{transform:translateY(-1px)}
.btn-ink{background:var(--ink);color:white;padding:.85rem 2rem}
.btn-ink:hover{background:var(--accent)}
.btn-ghost{background:none;color:var(--mid);padding:.85rem 1.5rem;border:1px solid var(--border)}
.btn-ghost:hover{color:var(--ink);border-color:var(--ink)}
.btn-white{background:white;color:var(--ink);padding:1rem 2.5rem;font-size:.8rem;font-weight:600}
.btn-white:hover{background:var(--accent);color:white}
.hero-nudge{font-size:.73rem;color:var(--mid);display:flex;align-items:center;gap:.4rem}
.hero-nudge::before{content:"👋"}
.hr{position:relative;overflow:hidden;background:var(--light)}
.hr img{width:100%;height:100%;object-fit:cover;object-position:center 20%}
.hbadges{position:absolute;top:1.75rem;right:1.75rem;display:flex;flex-direction:column;gap:.5rem}
.hb{background:rgba(255,255,255,.93);backdrop-filter:blur(8px);padding:.5rem .9rem;font-size:.71rem;font-weight:500;color:var(--ink);display:flex;align-items:center;gap:.45rem;box-shadow:0 2px 12px rgba(0,0,0,.1)}
.hb-dot{width:6px;height:6px;border-radius:50%;background:var(--accent);flex-shrink:0;animation:pulse 2.5s ease infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.35}}
.hbar{position:absolute;bottom:0;left:0;right:0;background:rgba(17,17,16,.9);backdrop-filter:blur(10px);display:flex}
.hbs{flex:1;padding:.95rem 1.25rem;border-right:1px solid rgba(255,255,255,.06);text-align:center}
.hbs:last-child{border-right:none}
.hbs-n{font-family:var(--serif);font-size:1.5rem;color:white;line-height:1}
.hbs-l{font-size:.57rem;letter-spacing:.1em;text-transform:uppercase;color:rgba(255,255,255,.38);margin-top:.2rem}

/* ─── MARQUEE ─── */
.mwrap{background:var(--ink);padding:.62rem 0;overflow:hidden}
.mtrack{display:flex;white-space:nowrap;animation:mq 30s linear infinite;width:max-content}
.mi{font-size:.67rem;letter-spacing:.16em;text-transform:uppercase;color:#555;padding:0 2rem;display:flex;align-items:center;gap:2rem}
.md{width:3px;height:3px;border-radius:50%;background:var(--accent);flex-shrink:0}
@keyframes mq{from{transform:translateX(0)}to{transform:translateX(-50%)}}

/* ─── LOGOS ─── */
.logos{background:var(--white);border-bottom:1px solid var(--border);padding:1.5rem 3rem}
.logos-in{max-width:1200px;margin:0 auto;display:flex;align-items:center;gap:2.5rem;flex-wrap:wrap}
.logos-lbl{font-size:.65rem;letter-spacing:.13em;text-transform:uppercase;color:var(--mid);white-space:nowrap;flex-shrink:0}
.logo-list{display:flex;gap:3rem;align-items:center;flex-wrap:wrap}
.logo-item{font-family:var(--sans);font-size:.85rem;font-weight:600;letter-spacing:.04em;color:var(--mid);opacity:.5;transition:opacity .25s,color .25s}
.logo-item:hover{opacity:1;color:var(--ink)}

/* ─── SHARED ─── */
.w{max-width:1200px;margin:0 auto}
.stag{font-size:.65rem;font-weight:500;letter-spacing:.18em;text-transform:uppercase;color:var(--accent);margin-bottom:.8rem}
.sh{font-family:var(--serif);font-size:clamp(1.95rem,3.4vw,3rem);line-height:1.08;letter-spacing:-.025em;color:var(--ink);font-weight:400}
.sh em{font-style:italic;color:var(--accent)}
.sh.inv{color:white}
.sh.inv em{color:var(--soft)}
.sb{font-size:.9rem;color:var(--mid);line-height:1.82;margin-top:.85rem;font-weight:300;max-width:540px}

/* ─── SERVICES ─── */
#services{padding:6.5rem 3rem;background:var(--bg)}
.svc-grid{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:var(--border);border:1px solid var(--border);margin-top:4rem}
.svc{background:var(--white);overflow:hidden;transition:background .25s}
.svc:hover{background:var(--bg)}
.svc-img{width:100%;height:420px;object-fit:cover;display:block;transition:transform .55s ease}
.svc:hover .svc-img{transform:scale(1.04)}
.svc-body{padding:2.25rem 2.25rem 2.5rem}
.svc-n{font-family:var(--serif);font-size:.9rem;color:var(--accent);font-style:italic;margin-bottom:.8rem}
.svc-title{font-family:var(--serif);font-size:1.4rem;color:var(--ink);margin-bottom:.85rem;line-height:1.18;font-weight:400}
.svc-desc{font-size:.85rem;color:var(--mid);line-height:1.8;margin-bottom:1.1rem;font-weight:300}
.svc-example{background:var(--bg);border-left:2px solid var(--border);padding:.65rem .95rem;font-size:.78rem;color:var(--mid);line-height:1.65;margin-bottom:1.1rem;font-style:italic}
.svc-example strong{font-style:normal;color:var(--ink);font-weight:500}
.svc-tags{display:flex;gap:.4rem;flex-wrap:wrap}
.svc-tag{font-size:.67rem;letter-spacing:.04em;background:var(--abg);color:var(--accent);padding:.2rem .6rem;border-radius:20px;font-weight:500}

/* ─── GALLERY ─── */
#gallery{background:var(--white);border-top:1px solid var(--border);padding:6rem 3rem}
.gal-grid{display:grid;grid-template-columns:repeat(4,1fr);grid-auto-rows:280px;gap:4px;margin-top:3rem}
.gi{overflow:hidden;background:var(--light);position:relative;cursor:pointer}
.gi img{width:100%;height:100%;object-fit:cover;display:block;transition:transform .6s cubic-bezier(.25,.1,.25,1)}
.gi:hover img{transform:scale(1.15)}
.gi.span2{grid-column:span 2;grid-row:span 2}
.gi-cap{position:absolute;bottom:0;left:0;right:0;background:linear-gradient(transparent,rgba(0,0,0,.7));padding:2.5rem .9rem .7rem;font-size:.69rem;color:rgba(255,255,255,.88);opacity:0;transition:opacity .3s;font-style:italic}
.gi:hover .gi-cap{opacity:1}
.lb-overlay{position:fixed;inset:0;z-index:9999;background:rgba(250,249,247,.35);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);display:none;align-items:center;justify-content:center;cursor:zoom-out;opacity:0;transition:opacity .35s ease}
.lb-overlay.active{display:flex;opacity:1}
.lb-overlay img{max-width:88vw;max-height:88vh;object-fit:contain;border-radius:8px;box-shadow:0 12px 80px rgba(0,0,0,.18),0 2px 16px rgba(0,0,0,.08);transform:scale(.95);transition:transform .35s cubic-bezier(.25,.1,.25,1)}
.lb-overlay.active img{transform:scale(1)}
.lb-close{position:fixed;top:1.2rem;right:1.5rem;color:var(--mid);font-size:1.8rem;cursor:pointer;z-index:10000;transition:color .2s;background:rgba(255,255,255,.6);border:1px solid var(--border);border-radius:50%;width:40px;height:40px;display:flex;align-items:center;justify-content:center;font-family:var(--sans)}
.lb-close:hover{color:var(--ink);background:rgba(255,255,255,.9)}
.lb-nav{position:fixed;top:50%;transform:translateY(-50%);background:rgba(255,255,255,.6);border:1px solid var(--border);color:var(--mid);width:44px;height:44px;border-radius:50%;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:1.3rem;z-index:10000;transition:background .2s,color .2s;font-family:var(--sans);border:none}
.lb-nav:hover{background:rgba(255,255,255,.9);color:var(--ink)}
.lb-prev{left:1.2rem}
.lb-next{right:1.2rem}
.lb-counter{position:fixed;bottom:1.2rem;left:50%;transform:translateX(-50%);color:var(--mid);font-size:.75rem;z-index:10000;font-family:var(--sans)}
.gi.a{grid-column:span 7;grid-row:span 2}
.gi.b{grid-column:span 5}
.gi.c{grid-column:span 5}
.gi.d{grid-column:span 4}
.gi.e{grid-column:span 4}
.gi.f{grid-column:span 4}

/* ─── FULLPRODUCT ─── */
#fullproduct{background:var(--ink);padding:5rem 3rem;color:white}
.fp-text{max-width:1200px;margin:0 auto;text-align:center;margin-bottom:3rem}
.fp-tag{font-size:.65rem;font-weight:500;letter-spacing:.18em;text-transform:uppercase;color:var(--soft);margin-bottom:.8rem}
.fp-h{font-family:var(--serif);font-size:clamp(1.9rem,3.2vw,2.8rem);line-height:1.1;letter-spacing:-.025em;color:white;font-weight:400;margin-bottom:1rem}
.fp-h em{font-style:italic;color:var(--soft)}
.fp-body{font-size:.88rem;color:rgba(255,255,255,.65);line-height:1.85;font-weight:300;margin-bottom:1.6rem;max-width:620px;margin-left:auto;margin-right:auto}
.fp-tags{display:flex;gap:.5rem;flex-wrap:wrap;justify-content:center;margin-bottom:3rem}
.fp-pill{font-size:.67rem;letter-spacing:.04em;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.12);color:rgba(255,255,255,.7);padding:.3rem .75rem;border-radius:20px;font-weight:500}
.fp-photos{max-width:1200px;margin:0 auto;display:grid;grid-template-columns:repeat(4,1fr);gap:4px}
.fp-photo{overflow:hidden;border-radius:4px;height:260px}
.fp-photo img{width:100%;height:100%;object-fit:cover;display:block;transition:transform .55s ease}
.fp-photo:hover img{transform:scale(1.1)}
.fp-label{font-size:.65rem;text-transform:uppercase;letter-spacing:.1em;color:rgba(255,255,255,.35);text-align:center;margin-top:.6rem}

/* ─── ABOUT ─── */
#about{border-top:1px solid var(--border)}
.about-grid{max-width:1200px;margin:0 auto;padding:6rem 3rem;display:grid;grid-template-columns:1.05fr 1fr;gap:5rem;align-items:center}
.about-img{width:100%;height:480px;object-fit:cover;object-position:center 20%;display:block}
.about-caption{background:var(--ink);padding:1.1rem 1.5rem;font-size:.77rem;color:rgba(255,255,255,.6);line-height:1.6;font-style:italic}
.about-q{font-family:var(--serif);font-size:clamp(1.45rem,2.6vw,2.4rem);line-height:1.2;letter-spacing:-.02em;color:var(--ink);font-weight:400}
.about-q em{font-style:italic;color:var(--accent)}
.about-body{font-size:.88rem;color:var(--mid);line-height:1.88;margin-top:1.4rem;font-weight:300}
.about-body p+p{margin-top:.9rem}
.about-nums{display:grid;grid-template-columns:1fr 1fr;gap:0;border:1px solid var(--border);margin-top:2.25rem}
.an{padding:1.35rem 1.5rem;border-right:1px solid var(--border);border-bottom:1px solid var(--border)}
.an:nth-child(2n){border-right:none}
.an:nth-child(3),.an:nth-child(4){border-bottom:none}
.an-n{font-family:var(--serif);font-size:2.2rem;line-height:1;color:var(--ink)}
.an-l{font-size:.63rem;letter-spacing:.1em;text-transform:uppercase;color:var(--mid);margin-top:.25rem}

/* ─── DELIVERY HERO ─── */
#delivery-hero{border-top:1px solid var(--border);display:grid;grid-template-columns:1fr 1fr}
.dh-img{overflow:hidden;height:380px}
.dh-img img{width:100%;height:100%;object-fit:cover;object-position:center 20%;display:block}
.dh-text{background:var(--ink);padding:4rem 3.5rem;display:flex;flex-direction:column;justify-content:center}
.dh-label{font-size:.65rem;letter-spacing:.16em;text-transform:uppercase;color:var(--accent);margin-bottom:1rem}
.dh-q{font-family:var(--serif);font-size:clamp(1.5rem,2.8vw,2.6rem);line-height:1.15;letter-spacing:-.02em;color:white;font-weight:400;margin-bottom:1.25rem}
.dh-q em{font-style:italic;color:var(--soft)}
.dh-body{font-size:.85rem;color:rgba(255,255,255,.55);line-height:1.8;font-weight:300}
.dh-stats{display:grid;grid-template-columns:1fr 1fr;gap:0;margin-top:2.25rem;border:1px solid #1e1e1c}
.ds{padding:1.1rem 1.25rem;border-right:1px solid #1e1e1c;border-bottom:1px solid #1e1e1c}
.ds:nth-child(2n){border-right:none}
.ds:nth-child(3),.ds:nth-child(4){border-bottom:none}
.ds-n{font-family:var(--serif);font-size:2rem;line-height:1;color:white}
.ds-l{font-size:.6rem;letter-spacing:.1em;text-transform:uppercase;color:rgba(255,255,255,.35);margin-top:.25rem}

/* ─── COMPARISON ─── */
#comparison{background:#0f0f0e;padding:6rem 3rem}
.comp-head{display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:end;margin-bottom:3.5rem}
.comp-img{width:100%;height:260px;object-fit:cover;object-position:center 30%}
.comp-table{display:grid;grid-template-columns:1fr 1fr;border:1px solid #1e1e1c}
.comp-col{border-right:1px solid #1e1e1c}
.comp-col:last-child{border-right:none}
.comp-hd{padding:.9rem 1.75rem;border-bottom:1px solid #1e1e1c;font-size:.66rem;letter-spacing:.16em;text-transform:uppercase}
.comp-hd.them{color:#2d2d2b}
.comp-hd.us{color:var(--accent)}
.comp-row{padding:.88rem 1.75rem;border-bottom:1px solid #191917;font-size:.84rem;display:flex;align-items:flex-start;gap:.7rem}
.comp-row:last-child{border-bottom:none}
.comp-col.them .comp-row{color:#2d2d2b}
.comp-col.us .comp-row{color:#a0a09a}
.comp-col.us .ci{color:var(--accent);font-weight:700;flex-shrink:0}
.comp-col.them .ci{color:#222220;flex-shrink:0}

/* ─── PROCESS ─── */
#process{background:var(--bg);border-top:1px solid var(--border);padding:6.5rem 3rem}
.psteps{margin-top:4rem;border-top:1px solid var(--border)}
.ps{display:grid;grid-template-columns:54px 1fr;gap:2.5rem;padding:2rem 0;border-bottom:1px solid var(--border);align-items:start}
.ps-n{font-family:var(--serif);font-size:1.8rem;color:var(--accent);font-style:italic;line-height:1;padding-top:.1rem}
.ps-right{}
.ps-title{font-size:.92rem;font-weight:600;color:var(--ink);line-height:1.3;margin-bottom:.3rem}
.ps-fear{font-size:.76rem;color:var(--accent);font-style:italic;margin-bottom:.5rem}
.ps-desc{font-size:.83rem;color:var(--mid);line-height:1.78;font-weight:300}

/* ─── TESTIMONIALS ─── */
#testimonials{background:var(--white);border-top:1px solid var(--border);padding:6rem 3rem}
.tgrid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;margin-top:3.5rem}
.tcard{background:var(--bg);border:1px solid var(--border);padding:2rem 1.85rem;display:flex;flex-direction:column;gap:1.25rem;transition:border-color .25s,box-shadow .25s}
.tcard:hover{border-color:var(--abdr);box-shadow:0 6px 24px rgba(0,0,0,.06)}
.tcard-stars{color:var(--accent);font-size:.85rem;letter-spacing:.1em}
.tcard-q{font-family:var(--serif);font-size:1rem;color:var(--ink);line-height:1.55;font-style:italic;font-weight:400}
.tcard-q::before{content:'\'\'';}
.tcard-q::after{content:'\'\'';}
.tcard-author{display:flex;align-items:center;gap:.75rem;margin-top:auto}
.tcard-av{width:38px;height:38px;border-radius:50%;background:var(--light);display:flex;align-items:center;justify-content:center;font-size:.85rem;font-weight:600;color:var(--mid);flex-shrink:0}
.tcard-name{font-size:.8rem;font-weight:600;color:var(--ink);line-height:1.2}
.tcard-role{font-size:.72rem;color:var(--mid)}

/* ─── FAQ ─── */
#faq{background:var(--bg);border-top:1px solid var(--border);padding:6.5rem 3rem}
.faq-in{max-width:1200px;margin:0 auto;display:grid;grid-template-columns:1fr 1.9fr;gap:6rem;align-items:start}
.faq-left{position:sticky;top:80px}
.faq-hint{font-size:.85rem;color:var(--mid);line-height:1.8;margin-top:1rem;font-weight:300}
.faq-link{display:inline-flex;align-items:center;gap:.35rem;margin-top:1.4rem;font-size:.78rem;font-weight:500;color:var(--accent);text-decoration:none;border-bottom:1px solid var(--abdr);padding-bottom:1px;transition:color .2s,border-color .2s}
.faq-link:hover{color:var(--ink);border-color:var(--ink)}
.faq-list{border-top:1px solid var(--border)}
.fi{border-bottom:1px solid var(--border)}
.fq{width:100%;background:none;border:none;cursor:pointer;text-align:left;padding:1.1rem 0;font-family:var(--sans);font-size:.88rem;font-weight:500;color:var(--ink);display:flex;justify-content:space-between;align-items:center;gap:1rem;transition:color .2s}
.fq:hover{color:var(--accent)}
.fqicon{width:15px;height:15px;flex-shrink:0;transition:transform .3s;color:var(--mid)}
.fi.open .fqicon{transform:rotate(45deg);color:var(--accent)}
.fa{max-height:0;overflow:hidden;transition:max-height .38s ease}
.fa p{font-size:.84rem;color:var(--mid);line-height:1.8;padding-bottom:1.1rem;font-weight:300}
.fi.open .fa{max-height:500px}

/* ─── CTA STRIP ─── */
#cta{background:var(--accent);padding:4.5rem 3rem}
.cta-in{max-width:1200px;margin:0 auto;display:grid;grid-template-columns:1fr auto;align-items:center;gap:3rem}
.cta-title{font-family:var(--serif);font-size:clamp(1.8rem,3.2vw,3.2rem);color:white;line-height:1.08;letter-spacing:-.025em;font-weight:400}
.cta-title em{font-style:italic}
.cta-sub{font-size:.87rem;color:rgba(255,255,255,.7);margin-top:.65rem;font-weight:300}

/* ─── CONTACT ─── */
#contact{background:var(--bg);border-top:1px solid var(--border);padding:6.5rem 3rem}
.contact-in{max-width:1200px;margin:0 auto;display:grid;grid-template-columns:1fr 1.4fr;gap:6.5rem;align-items:start}
.ch2{font-family:var(--serif);font-size:clamp(1.85rem,3.2vw,3rem);line-height:1.08;letter-spacing:-.025em;margin-bottom:1.1rem;font-weight:400}
.ch2 em{font-style:italic;color:var(--accent)}
.contact-body{font-size:.87rem;color:var(--mid);line-height:1.82;margin-bottom:1.5rem;font-weight:300}
.contact-callout{background:var(--abg);border:1px solid var(--abdr);padding:.95rem 1.15rem;font-size:.78rem;color:var(--accent);line-height:1.65;margin-bottom:2rem;display:flex;gap:.5rem;align-items:flex-start}
.contact-callout::before{content:"💬";flex-shrink:0}
.cd{margin-bottom:1rem}
.cd-lbl{font-size:.59rem;letter-spacing:.16em;text-transform:uppercase;color:var(--accent);margin-bottom:.18rem}
.cd-val{font-size:.87rem;color:var(--ink)}
.cd-val a{color:var(--ink);text-decoration:none;border-bottom:1px solid var(--border);transition:border-color .2s}
.cd-val a:hover{border-color:var(--accent)}
.form-r{margin-bottom:.85rem}
.form-r label{display:block;font-size:.6rem;letter-spacing:.1em;text-transform:uppercase;color:var(--mid);margin-bottom:.35rem}
.form-r input,.form-r select,.form-r textarea{width:100%;background:var(--white);border:1px solid var(--border);border-radius:2px;padding:.72rem 1rem;font-family:var(--sans);font-size:.87rem;color:var(--ink);outline:none;transition:border-color .2s,box-shadow .2s;appearance:none}
.form-r input:focus,.form-r select:focus,.form-r textarea:focus{border-color:var(--accent);box-shadow:0 0 0 3px rgba(201,78,30,.07)}
.form-r input::placeholder,.form-r textarea::placeholder{color:#c8c4bc}
.form-r textarea{height:100px;resize:none}
.form-r select{cursor:pointer}
.fg2{display:grid;grid-template-columns:1fr 1fr;gap:.85rem}
.fsub{width:100%;margin-top:.4rem;background:var(--ink);color:white;border:none;cursor:pointer;font-family:var(--sans);font-size:.82rem;font-weight:500;padding:.95rem;border-radius:2px;transition:background .2s,transform .15s;display:flex;align-items:center;justify-content:center;gap:.35rem}
.fsub:hover{background:var(--accent);transform:translateY(-1px)}
.form-note{font-size:.7rem;color:var(--mid);text-align:center;margin-top:.55rem;font-style:italic}
.form-or{text-align:center;font-size:.75rem;color:var(--mid);margin:.9rem 0;position:relative}
.form-or::before,.form-or::after{content:'';position:absolute;top:50%;width:42%;height:1px;background:var(--border)}
.form-or::before{left:0}.form-or::after{right:0}

/* ─── FOOTER ─── */
footer{background:var(--ink);padding:2.25rem 3rem;display:flex;align-items:center;justify-content:space-between}
.fl{font-family:var(--serif);font-size:1.2rem;color:white;letter-spacing:-.02em}
.fl b{color:var(--accent);font-weight:400}
.flinks{display:flex;gap:2rem;list-style:none}
.flinks a{font-size:.68rem;letter-spacing:.08em;text-transform:uppercase;color:#444;text-decoration:none;transition:color .2s}
.flinks a:hover{color:white}
.fcopy{font-size:.68rem;color:#333;letter-spacing:.03em}

/* ─── REVEAL ─── */
.rv{opacity:0;transform:translateY(16px);transition:opacity .65s ease,transform .65s ease}
.rv.in{opacity:1;transform:none}
.d1{transition-delay:.1s}.d2{transition-delay:.2s}.d3{transition-delay:.3s}.d4{transition-delay:.4s}

/* ─── LANG ─── */
[data-lang]{display:none}
[data-lang].on{display:block}
span[data-lang].on,em[data-lang].on,strong[data-lang].on{display:inline}

/* ─── RESPONSIVE ─── */
@media(max-width:980px){
  nav{padding:0 1.5rem}.nav-links{display:none}
  #hero{grid-template-columns:1fr}.hr{height:300px}.hl{padding:4rem 1.5rem 3rem}
  .logos{padding:1.5rem 1.5rem}
  #services,.about-grid,#comparison,#process,#testimonials,#faq,#cta,#contact{padding:4rem 1.5rem}
  #gallery{padding:4rem 1.5rem}
  .svc-grid{grid-template-columns:1fr}
  .about-grid{grid-template-columns:1fr;gap:3rem}.about-img{height:320px}
  #fullproduct{padding:4rem 1.5rem}.fp-photos{grid-template-columns:1fr 1fr}.fp-photo{height:200px}
  #delivery-hero{grid-template-columns:1fr}.dh-img{height:260px}.dh-text{padding:3rem 1.5rem}
  .comp-head{grid-template-columns:1fr;gap:2rem}.comp-img{height:200px}
  .comp-table{grid-template-columns:1fr}.comp-col{border-right:none;border-bottom:1px solid #1e1e1c}
  .tgrid{grid-template-columns:1fr}
  .faq-in{grid-template-columns:1fr;gap:3rem}.faq-left{position:static}
  .cta-in{grid-template-columns:1fr;gap:2rem}
  .contact-in{grid-template-columns:1fr;gap:3rem}.fg2{grid-template-columns:1fr}
  .gal-grid{grid-template-columns:1fr 1fr;grid-auto-rows:180px}
  .gi.span2{grid-column:span 2;grid-row:span 1}
  footer{flex-direction:column;gap:1.4rem;text-align:center;padding:2rem 1.5rem}
  .flinks{justify-content:center;flex-wrap:wrap}
}
@media(max-width:540px){
  .gal-grid{grid-template-columns:1fr}.gi.span2{grid-column:span 1}
  .dh-stats{grid-template-columns:1fr}
  .ds{border-right:none!important;border-bottom:1px solid #1e1e1c!important}
  .ds:last-child{border-bottom:none!important}
}
</style>
</head>
