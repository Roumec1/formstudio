<!-- ── HERO ── -->
<section id="hero">
  <div class="hl">
    <div class="hero-tag">
      <span data-lang="cs" class="on">Výroba na zakázku · Šumperk, Morava</span>
      <span data-lang="sk">Výroba na zákazku · Šumperk, Morava</span>
      <span data-lang="en">Custom manufacturing · Šumperk, Moravia</span>
      <span data-lang="de">Auftragsfertigung · Šumperk, Mähren</span>
      <span data-lang="en">Custom manufacturing · Šumperk, Moravia</span>
      <span data-lang="de">Auftragsfertigung · Šumperk, Mähren</span>
    </div>
    <h1>
      <span data-lang="cs" class="on">Máte nápad.<br>My ho <em>vyrobíme.</em></span>
      <span data-lang="sk">Máte nápad.<br>My ho <em>vyrobíme.</em></span>
      <span data-lang="en">You have an idea.<br>We <em>make it.</em></span>
      <span data-lang="de">Sie haben eine Idee.<br>Wir <em>fertigen sie.</em></span>
      <span data-lang="en">You have an idea.<br>We <em>make it.</em></span>
      <span data-lang="de">Sie haben eine Idee.<br>Wir <em>fertigen sie.</em></span>
    </h1>
    <p class="hero-sub">
      <span data-lang="cs" class="on">CNC frézování, 3D tisk, laserové gravírování — <strong>od 1 kusu po tisíce.</strong> Pošlete nám soubor nebo jen nápad. Zbytek je na nás.</span>
      <span data-lang="sk">CNC frézovanie, 3D tlač, laserové gravírovanie — <strong>od 1 kusu po tisíce.</strong> Pošlite nám súbor alebo len nápad. Zvyšok je na nás.</span>
      <span data-lang="en">CNC milling, 3D printing, laser engraving — <strong>from 1 piece to thousands.</strong> Send us a file or just an idea. We handle the rest.</span>
      <span data-lang="de">CNC-Fräsen, 3D-Druck, Lasergravur — <strong>von 1 Stück bis Tausende.</strong> Schicken Sie uns eine Datei oder einfach eine Idee. Den Rest übernehmen wir.</span>
    </p>
    <p class="hero-proof">
      <span data-lang="cs" class="on">Vyrobili jsme pro <strong>Cloudflare, Mastercard, Bohemia Interactive</strong> a stovky dalších.</span>
      <span data-lang="sk">Vyrobili sme pre <strong>Cloudflare, Mastercard, Bohemia Interactive</strong> a stovky ďalších.</span>
      <span data-lang="en">We have produced for <strong>Cloudflare, Mastercard, Bohemia Interactive</strong> and hundreds more.</span>
      <span data-lang="de">Wir haben für <strong>Cloudflare, Mastercard, Bohemia Interactive</strong> und Hunderte weitere produziert.</span>
    </p>
    <div class="hero-btns">
      <a class="btn btn-ink" href="#contact">
        <span data-lang="cs" class="on">Pošlete nám projekt →</span>
        <span data-lang="sk">Pošlite nám projekt →</span>
        <span data-lang="en">Send us your project →</span>
        <span data-lang="de">Senden Sie uns Ihr Projekt →</span>
        <span data-lang="en">Send us your project →</span>
        <span data-lang="de">Senden Sie uns Ihr Projekt →</span>
      </a>
      <a class="btn btn-ghost" href="#gallery">
        <span data-lang="cs" class="on">Podívejte se na ukázky</span>
        <span data-lang="sk">Pozrite sa na ukážky</span>
        <span data-lang="en">See our work</span>
        <span data-lang="de">Unsere Arbeiten ansehen</span>
        <span data-lang="en">See our work</span>
        <span data-lang="de">Unsere Arbeiten ansehen</span>
      </a>
    </div>
    <p class="hero-nudge">
      <span data-lang="cs" class="on">Odpovídáme do 24 hodin. Žádné závazky.</span>
      <span data-lang="sk">Odpovedáme do 24 hodín. Žiadne záväzky.</span>
      <span data-lang="en">We reply within 24 hours. No obligations.</span>
      <span data-lang="de">Wir antworten innerhalb von 24 Stunden. Unverbindlich.</span>
    </p>
  </div>
  <div class="hr">
    <img src="images/cnc-frzka-v-provozu.jpg" alt="CNC frézka v provozu">
    <div class="hbadges">
      <div class="hb"><span class="hb-dot"></span><span data-lang="cs" class="on">Komplexní projekty vítány</span><span data-lang="sk">Komplexné projekty vítané</span><span data-lang="en">Complex projects welcome</span><span data-lang="de">Komplexe Projekte willkommen</span></div>
      <div class="hb"><span class="hb-dot"></span><span data-lang="cs" class="on">Série od 1 kusu</span><span data-lang="sk">Série od 1 kusu</span><span data-lang="en">Series from 1 piece</span><span data-lang="de">Serie ab 1 Stück</span></div>
      <div class="hb"><span class="hb-dot"></span><span data-lang="cs" class="on">Nabídka do 48 hodin</span><span data-lang="sk">Ponuka do 48 hodín</span><span data-lang="en">Quote in 48 hours</span><span data-lang="de">Angebot in 48 Stunden</span></div>
    </div>
    <div class="hbar">
      <div class="hbs"><div class="hbs-n">500+</div><div class="hbs-l"><span data-lang="cs" class="on">Projektů</span><span data-lang="sk">Projektov</span><span data-lang="en">Projects</span><span data-lang="de">Projekte</span></div></div>
      <div class="hbs"><div class="hbs-n">5 let</div><div class="hbs-l"><span data-lang="cs" class="on">V oboru</span><span data-lang="sk">V odbore</span><span data-lang="en">Years in industry</span><span data-lang="de">Jahre in der Industrie</span></div></div>
      <div class="hbs"><div class="hbs-n">48 h</div><div class="hbs-l"><span data-lang="cs" class="on">Nabídka</span><span data-lang="sk">Ponuka</span><span data-lang="en">Quote</span><span data-lang="de">Angebot</span></div></div>
      <div class="hbs"><div class="hbs-n">98 %</div><div class="hbs-l"><span data-lang="cs" class="on">V termínu</span><span data-lang="sk">V termíne</span><span data-lang="en">On time</span><span data-lang="de">Pünktlich</span></div></div>
    </div>
  </div>
</section>

