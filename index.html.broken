<!-- ── PROCESS ── -->
<section id="process">
  <div class="w rv">
    <p class="stag"><span data-lang="cs" class="on">Jak to funguje</span><span data-lang="sk">Ako to funguje</span><span data-lang="en">How it works</span><span data-lang="de">So funktioniert es</span></p>
    <h2 class="sh"><span data-lang="cs" class="on">Od poptávky k výrobku — <em>pět kroků.</em></span><span data-lang="sk">Od dopytu k výrobku — <em>päť krokov.</em></span><span data-lang="en">From inquiry to product — <em>five steps.</em></span><span data-lang="de">Von der Anfrage zum Produkt — <em>fünf Schritte.</em></span></h2>
    <p class="sb"><span data-lang="cs" class="on">Snažíme se, aby byl celý proces co nejjednodušší. Soubor nemusí být perfektní. Nápad stačí.</span><span data-lang="sk">Snažíme sa, aby bol celý proces čo najjednoduchší. Súbor nemusí byť perfektný. Nápad stačí.</span><span data-lang="en">We try to make the whole process as simple as possible. The file doesn't have to be perfect. The idea is what matters.</span><span data-lang="de">Wir versuchen, den gesamten Prozess so einfach wie möglich zu gestalten. Die Datei muss nicht perfekt sein. Die Idee ist das Wichtigste.</span></p>
  </div>
  <div class="w">
    <div class="psteps">
      <div class="ps rv">
        <div class="ps-n">1</div>
        <div class="ps-right">
          <div class="ps-title"><span data-lang="cs" class="on">Pošlete poptávku nebo soubor</span><span data-lang="sk">Pošlite dopyt alebo súbor</span><span data-lang="en">Send a request or file</span><span data-lang="de">Eine Anfrage oder Datei senden</span></div>
          <div class="ps-fear"><span data-lang="cs" class="on">Soubor nemusí být dokonalý — klidně pošlete PDF, náčrt, nebo jen pár vět.</span><span data-lang="sk">Súbor nemusí byť dokonalý — pokojne pošlite PDF, náčrt, alebo len pár viet.</span><span data-lang="en">The file doesn't have to be perfect — feel free to send a PDF, sketch, or just a few lines.</span><span data-lang="de">Die Datei muss nicht perfekt sein — senden Sie gerne ein PDF, eine Skizze oder nur ein paar Zeilen.</span></div>
          <p class="ps-desc"><span data-lang="cs" class="on">Vyplňte formulář níže nebo napište e-mail. K ničemu se nezavazujete. Přijmeme DXF, STL, STEP, PDF, SolidWorks, Fusion 360 i obyčejné fotky náčrtu.</span><span data-lang="sk">Vyplňte formulár nižšie alebo napíšte e-mail. K ničomu sa nezaväzujete. Prijmeme DXF, STL, STEP, PDF, SolidWorks, Fusion 360 aj obyčajné fotky náčrtu.</span><span data-lang="en">Fill out the form below or send an email. No obligation. We accept DXF, STL, STEP, PDF, SolidWorks, Fusion 360 and even ordinary sketch photos.</span><span data-lang="de">Füllen Sie das folgende Formular aus oder senden Sie eine E-Mail. Keine Verpflichtung. Wir akzeptieren DXF, STL, STEP, PDF, SolidWorks, Fusion 360 und sogar einfache Skizzenfoto.</span></p>
        </div>
      </div>
      <div class="ps rv">
        <div class="ps-n">2</div>
        <div class="ps-right">
          <div class="ps-title"><span data-lang="cs" class="on">Zavoláme si — do 24 hodin</span><span data-lang="sk">Zavoláme si — do 24 hodín</span><span data-lang="en">We'll call — within 24 hours</span><span data-lang="de">Wir rufen an — innerhalb von 24 Stunden</span></div>
          <div class="ps-fear"><span data-lang="cs" class="on">Nevíte, jakou technologii zvolit? Poradíme — bez žargonu, bez obchodních tlaků.</span><span data-lang="sk">Neviete, akú technológiu zvoliť? Poradíme — bez žargónu, bez obchodných tlakov.</span><span data-lang="en">Not sure which technology to choose? We'll advise — no jargon, no sales pressure.</span><span data-lang="de">Nicht sicher, welche Technologie Sie wählen sollen? Wir beraten — kein Jargon, kein Verkaufsdruck.</span></div>
          <p class="ps-desc"><span data-lang="cs" class="on">Ozveme se osobně, prodiskutujeme projekt a zodpovíme všechny otázky. Krátký hovor, který ušetří hodiny e-mailování.</span><span data-lang="sk">Ozveme sa osobne, prediskutujeme projekt a zodpovieme všetky otázky. Krátky hovor, ktorý ušetrí hodiny e-mailovania.</span><span data-lang="en">We'll get back to you personally, discuss the project and answer all questions. A short call that saves hours of email.</span><span data-lang="de">Wir melden uns persönlich, besprechen das Projekt und beantworten alle Fragen. Ein kurzes Gespräch, das Stunden E-Mail spart.</span></p>
        </div>
      </div>
      <div class="ps rv">
        <div class="ps-n">3</div>
        <div class="ps-right">
          <div class="ps-title"><span data-lang="cs" class="on">Jasná cena — žádná překvapení</span><span data-lang="sk">Jasná cena — žiadne prekvapenia</span><span data-lang="en">Clear price — no surprises</span><span data-lang="de">Klarer Preis — keine Überraschungen</span></div>
          <div class="ps-fear"><span data-lang="cs" class="on">U větších zakázek nabídneme fyzický vzorek ještě před potvrzením.</span><span data-lang="sk">Pri väčších zákazkách ponúkneme fyzickú vzorku ešte pred potvrdením.</span><span data-lang="en">For larger orders we'll offer a physical sample before confirmation.</span><span data-lang="de">Für größere Bestellungen bieten wir vor der Bestätigung ein physisches Muster an.</span></div>
          <p class="ps-desc"><span data-lang="cs" class="on">Dostanete jasnou kalkulaci bez skrytých poplatků. Pokud se cokoliv změní, okamžitě vám dáme vědět.</span><span data-lang="sk">Dostanete jasnú kalkuláciu bez skrytých poplatkov. Ak sa čokoľvek zmení, okamžite vám dáme vedieť.</span><span data-lang="en">You'll get a clear quote with no hidden fees. If anything changes, we let you know right away.</span><span data-lang="de">Sie erhalten ein klares Angebot ohne versteckte Gebühren. Wenn sich etwas ändert, teilen wir es Ihnen sofort mit.</span></p>
        </div>
      </div>
      <div class="ps rv">
        <div class="ps-n">4</div>
        <div class="ps-right">
          <div class="ps-title"><span data-lang="cs" class="on">Výroba — s průběžnou kontrolou</span><span data-lang="sk">Výroba — s priebežnou kontrolou</span><span data-lang="en">Production — with ongoing control</span><span data-lang="de">Produktion — mit laufender Kontrolle</span></div>
          <div class="ps-fear"><span data-lang="cs" class="on">U větších sérií posíláme průběžné fotky — abyste měli přehled.</span><span data-lang="sk">Pri väčších sériách posielame priebežné fotky — aby ste mali prehľad.</span><span data-lang="en">For larger series we send progress photos — so you stay informed.</span><span data-lang="de">Für größere Serien senden wir Fortschrittsfotos — damit Sie informiert bleiben.</span></div>
          <p class="ps-desc"><span data-lang="cs" class="on">Potvrdíte design a my se pustíme do práce. Každý kus prochází interní QC kontrolou. Na vyžádání dostanete protokol s naměřenými hodnotami.</span><span data-lang="sk">Potvrdíte dizajn a my sa pustíme do práce. Každý kus prechádza internou QC kontrolou. Na vyžiadanie dostanete protokol s nameranými hodnotami.</span><span data-lang="en">You confirm the design and we get to work. Every piece goes through internal QC. On request, you get a report with measured values.</span><span data-lang="de">Sie bestätigen das Design und wir machen uns an die Arbeit. Jedes Stück durchläuft eine interne Qualitätskontrolle. Auf Anfrage erhalten Sie einen Bericht mit gemessenen Werten.</span></p>
        </div>
      </div>
      <div class="ps rv">
        <div class="ps-n">5</div>
        <div class="ps-right">
          <div class="ps-title"><span data-lang="cs" class="on">Doručíme — přesně a včas</span><span data-lang="sk">Doručíme — presne a včas</span><span data-lang="en">Shipping — precisely and on time</span><span data-lang="de">Versand — präzise und pünktlich</span></div>
          <div class="ps-fear"><span data-lang="cs" class="on">Pokud se cokoliv zkomplikuje — jako první vám zavoláme.</span><span data-lang="sk">Ak sa čokoľvek skomplikuje — ako prví vám zavoláme.</span><span data-lang="en">If anything gets complicated — we call you first.</span><span data-lang="de">Wenn sich etwas kompliziert — wir rufen Sie zuerst an.</span></div>
          <p class="ps-desc"><span data-lang="cs" class="on">Na jednu adresu nebo na padesát. Kurýrem, spedičně nebo osobně. 98 % zakázek dodáváme v dohodnutém termínu nebo dříve.</span><span data-lang="sk">Na jednu adresu alebo na päťdesiat. Kuriérom, špeditérsky alebo osobne. 98 % zákaziek dodávame v dohodnutom termíne alebo skôr.</span><span data-lang="en">To one address or fifty. By courier, freight or in person. We deliver 98% of orders on schedule or early.</span><span data-lang="de">An eine Adresse oder fünfzig. Per Kurier, Spedition oder persönlich. Wir liefern 98 % der Bestellungen pünktlich oder früher ab.</span></p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ── TESTIMONIALS ── -->
<section id="testimonials">
  <div class="w rv">
    <p class="stag"><span data-lang="cs" class="on">Co říkají zákazníci</span><span data-lang="sk">Čo hovoria zákazníci</span><span data-lang="en">What customers say</span><span data-lang="de">Was Kunden sagen</span></p>
    <h2 class="sh"><span data-lang="cs" class="on">Neříkejte to za nás — <em>říkají to oni.</em></span><span data-lang="sk">Nehovorte to za nás — <em>hovoria to oni.</em></span><span data-lang="en">Don't take our word for it — <em>hear theirs.</em></span><span data-lang="de">Nehmen Sie nicht unser Wort — <em>hören Sie deren.</em></span></h2>
  </div>
  <div class="w">
    <div class="tgrid">
      <div class="tcard rv">
        <div class="tcard-stars">★★★★★</div>
        <p class="tcard-q"><span data-lang="cs" class="on">Potřebovali jsme 300 dřevěných podtácků s logem za týden. Forma to zvládla s přehledem — každý kus identický, dodáno dva dny předem. Napřesrok jdeme znovu.</span><span data-lang="sk">Potrebovali sme 300 drevených podtácok s logom za týždeň. Forma to zvládla s prehľadom — každý kus identický, dodané dva dni vopred. O rok ideme znovu.</span><span data-lang="en">We needed 300 wooden coasters with logo in a week. Forma handled it easily — every piece identical, delivered two days early. We're back next year.</span><span data-lang="de">Wir brauchten 300 Holzuntersetzer mit Logo in einer Woche. Forma schaffte es locker — jedes Stück identisch, zwei Tage früher geliefert. Nächstes Jahr gehen wir wieder.</span></p>
        <div class="tcard-author">
          <div class="tcard-av">MK</div>
          <div>
            <div class="tcard-name">Markéta Kovářová</div>
            <div class="tcard-role"><span data-lang="cs" class="on">Marketing Manager · Myco</span><span data-lang="sk">Marketing Manager · Myco</span><span data-lang="en">Marketing Manager · Myco</span><span data-lang="de">Marketing Manager · Myco</span></div>
          </div>
        </div>
      </div>
      <div class="tcard rv d1">
        <div class="tcard-stars">★★★★★</div>
        <p class="tcard-q"><span data-lang="cs" class="on">Pět iterací prototypu za dva týdny. Jiní výrobci mi říkali, že to za měsíc nestihnou. Forma to vzala jako výzvu. Výsledek byl přesně to, co jsem potřeboval na pitch.</span><span data-lang="sk">Päť iterácií prototypu za dva týždne. Iní výrobcovia mi hovorili, že to za mesiac nestihnú. Forma to vzala ako výzvu. Výsledok bol presne to, čo som potreboval na pitch.</span><span data-lang="en">Five prototype iterations in two weeks. Other manufacturers said they couldn't do it in a month. Forma took it as a challenge. The result was exactly what I needed for the pitch.</span><span data-lang="de">Fünf Prototyp-Iterationen in zwei Wochen. Andere Hersteller sagten mir, dass sie es in einem Monat nicht schaffen. Forma nahm es als Herausforderung an. Das Ergebnis war genau das, was ich für meine Präsentation brauchte.</span></p>
        <div class="tcard-author">
          <div class="tcard-av">TN</div>
          <div>
            <div class="tcard-name">Tomáš Novotný</div>
            <div class="tcard-role"><span data-lang="cs" class="on">Founder · Hardwear Labs</span><span data-lang="sk">Founder · Hardwear Labs</span><span data-lang="en">Founder · Hardwear Labs</span><span data-lang="de">Founder · Hardwear Labs</span></div>
          </div>
        </div>
      </div>
      <div class="tcard rv d2">
        <div class="tcard-stars">★★★★★</div>
        <p class="tcard-q"><span data-lang="cs" class="on">Konečně výrobce, který si přečte brief a ještě zavolá, aby se ujistil, že správně rozumí. Žádný žargon, žádné překvapení na faktuře. Takového partnera hledáme.</span><span data-lang="sk">Konečne výrobca, ktorý si prečíta brief a ešte zavolá, aby sa uistil, že správne rozumie. Žiadny žargón, žiadne prekvapenie na faktúre. Takého partnera hľadáme.</span><span data-lang="en">Finally a manufacturer who reads the brief and calls to make sure they understand correctly. No jargon, no surprises on the invoice. That's the partner we're looking for.</span><span data-lang="de">Endlich ein Hersteller, der das Brief liest und anruft, um sicherzustellen, dass er richtig versteht. Kein Jargon, keine Überraschungen auf der Rechnung. Das ist der Partner, den wir suchen.</span></p>
        <div class="tcard-author">
          <div class="tcard-av">LP</div>
          <div>
            <div class="tcard-name">Lucie Procházková</div>
            <div class="tcard-role"><span data-lang="cs" class="on">Produktová designérka · Studio Arch+</span><span data-lang="sk">Produktová dizajnérka · Studio Arch+</span><span data-lang="en">Product Designer · Studio Arch+</span><span data-lang="de">Produktdesigner · Studio Arch+</span></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ── FAQ ── -->
<section id="faq">
  <div class="faq-in">
    <div class="faq-left rv">
      <p class="stag">FAQ</p>
      <h2 class="sh"><span data-lang="cs" class="on">Otázky, které vás <em>právě napadají</em></span><span data-lang="sk">Otázky, ktoré vás <em>práve napadajú</em></span><span data-lang="en">Questions you're <em>probably asking</em></span><span data-lang="de">Fragen, die Sie sich <em>gerade stellen</em></span></h2>
      <p class="faq-hint"><span data-lang="cs" class="on">Tady jsou nejčastější věci, na které se nás lidé ptají. Nenašli jste odpověď? Napište nám — rádi poradíme.</span><span data-lang="sk">Tu sú najčastejšie veci, na ktoré sa nás ľudia pýtajú. Nenašli ste odpoveď? Napíšte nám — radi poradíme.</span><span data-lang="en">Here are the most common things people ask us. Didn't find an answer? Write to us — we're happy to help.</span><span data-lang="de">Hier sind die häufigsten Dinge, die uns Menschen fragen. Keine Antwort gefunden? Schreiben Sie uns — wir helfen gerne.</span></p>
      <a class="faq-link" href="#contact"><span data-lang="cs" class="on">Napsat dotaz →</span><span data-lang="sk">Napísať dotaz →</span><span data-lang="en">Ask a question →</span><span data-lang="de">Eine Frage stellen →</span></a>
    </div>
    <div class="faq-list rv d1">
      <div class="fi">
        <button class="fq" onclick="tog(this)">
          <span data-lang="cs" class="on">Nevím, jakou technologii zvolit. Pomůžete mi?</span><span data-lang="sk">Neviem, akú technológiu zvoliť. Pomôžete mi?</span><span data-lang="en">I don't know which technology to choose. Can you help?</span><span data-lang="de">Ich weiß nicht, welche Technologie ich wählen soll. Können Sie mir helfen?</span>
          <svg class="fqicon" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="9" y1="2" x2="9" y2="16"/><line x1="2" y1="9" x2="16" y2="9"/></svg>
        </button>
        <div class="fa"><p><span data-lang="cs" class="on">Samozřejmě — to je jedna z věcí, které děláme nejraději. Pošlete nám popis nebo náčrt a zavoláme si. Vysvětlíme rozdíly, navrhneme nejlepší řešení a poradíme s materiálem. Bez závazků, bez žargonu.</span><span data-lang="sk">Samozrejme — to je jedna z vecí, ktoré robíme najradšej. Pošlite nám popis alebo náčrt a zavoláme si. Vysvetlíme rozdiely, navrhneme najlepšie riešenie a poradíme s materiálom. Bez záväzkov, bez žargónu.</span><span data-lang="en">Of course — that's one of the things we love to do. Send us a description or sketch and let's call. We'll explain the differences, suggest the best solution, and advise on materials. No obligations, no jargon.</span><span data-lang="de">Natürlich — das ist eine der Dinge, die wir am liebsten tun. Senden Sie uns eine Beschreibung oder Skizze und lassen Sie uns anrufen. Wir erklären die Unterschiede, schlagen die beste Lösung vor und beraten zum Material. Keine Verpflichtungen, kein Jargon.</span></p></div>
      </div>
      <div class="fi">
        <button class="fq" onclick="tog(this)">
          <span data-lang="cs" class="on">Jaké je minimální množství objednávky?</span><span data-lang="sk">Aké je minimálne množstvo objednávky?</span><span data-lang="en">What's the minimum order quantity?</span><span data-lang="de">Was ist die Mindestbestellmenge?</span>
          <svg class="fqicon" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="9" y1="2" x2="9" y2="16"/><line x1="2" y1="9" x2="16" y2="9"/></svg>
        </button>
        <div class="fa"><p><span data-lang="cs" class="on">Žádné minimum. Vyrábíme od 1 kusu — prototyp, unikátní výstavu nebo tisícovou sérii. Ke každé zakázce přistupujeme se stejnou péčí. Cena se samozřejmě s množstvím škáluje, ale malá zakázka u nás není druhá kategorie.</span><span data-lang="sk">Žiadne minimum. Vyrábame od 1 kusu — prototyp, unikátnu výstavu alebo tisícovú sériu. Ku každej zákazke pristupujeme s rovnakou starostlivosťou. Cena sa samozrejme s množstvom škáluje, ale malá zákazka u nás nie je druhá kategória.</span><span data-lang="en">No minimum. We produce from 1 piece — prototype, unique exhibition or thousand-piece series. We approach every order with the same care. Price scales with volume, of course, but a small order is not second-class with us.</span><span data-lang="de">Kein Minimum. Wir produzieren ab 1 Stück — Prototyp, einzigartige Ausstellung oder tausendfach gefertigte Serie. Wir gehen mit jeder Bestellung gleich sorgfältig um. Der Preis skaliert natürlich mit dem Volumen, aber eine kleine Bestellung ist bei uns nicht zweite Wahl.</span></p></div>
      </div>
      <div class="fi">
        <button class="fq" onclick="tog(this)">
          <span data-lang="cs" class="on">Jaké formáty souborů přijímáte?</span><span data-lang="sk">Aké formáty súborov prijímate?</span><span data-lang="en">What file formats do you accept?</span><span data-lang="de">Welche Dateiformate akzeptieren Sie?</span>
          <svg class="fqicon" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="9" y1="2" x2="9" y2="16"/><line x1="2" y1="9" x2="16" y2="9"/></svg>
        </button>
        <div class="fa"><p><span data-lang="cs" class="on">DXF, STL, STEP, IGES, SolidWorks, Fusion 360, PDF — a zvládneme i technický výkres nebo fotografii náčrtu. Ještě nikdo nás nepřekvapil souborem, se kterým bychom si neporadili. Pokud si nejste jistí — prostě pošlete, co máte.</span><span data-lang="sk">DXF, STL, STEP, IGES, SolidWorks, Fusion 360, PDF — a zvládneme aj technický výkres alebo fotografiu náčrtu. Ešte nikto nás neprekvapil súborom, s ktorým by sme si neporadili. Ak si nie ste istí — jednoducho pošlite, čo máte.</span><span data-lang="en">DXF, STL, STEP, IGES, SolidWorks, Fusion 360, PDF — and we can handle technical drawings or photos of sketches. No one has surprised us with a file we couldn't handle. If you're not sure — just send what you have.</span><span data-lang="de">DXF, STL, STEP, IGES, SolidWorks, Fusion 360, PDF — und wir können technische Zeichnungen oder Fotos von Skizzen verarbeiten. Niemand hat uns mit einer Datei überrascht, mit der wir nicht umgehen konnten. Wenn Sie sich nicht sicher sind — senden Sie einfach, was Sie haben.</span></p></div>
      </div>
      <div class="fi">
        <button class="fq" onclick="tog(this)">
          <span data-lang="cs" class="on">Jak dlouho výroba trvá?</span><span data-lang="sk">Ako dlho výroba trvá?</span><span data-lang="en">How long does production take?</span><span data-lang="de">Wie lange dauert die Herstellung?</span>
          <svg class="fqicon" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="9" y1="2" x2="9" y2="16"/><line x1="2" y1="9" x2="16" y2="9"/></svg>
        </button>
        <div class="fa"><p><span data-lang="cs" class="on">Prototypy standardně do 48 hodin. Malosériová výroba (10–200 ks): 1–2 týdny. Větší série: 2–4 týdny podle složitosti. Máte šibeniční termín? Zavolejte nám — uděláme vše pro to, aby to vyšlo.</span><span data-lang="sk">Prototypy štandardne do 48 hodín. Malosériová výroba (10–200 ks): 1–2 týždne. Väčšie série: 2–4 týždne podľa zložitosti. Máte šibeničný termín? Zavolajte nám — urobíme všetko pre to, aby to vyšlo.</span><span data-lang="en">Prototypes usually in 48 hours. Small series (10-200 pcs): 1-2 weeks. Larger series: 2-4 weeks depending on complexity. Need it ASAP? Call us — we'll do everything we can to make it work.</span><span data-lang="de">Prototypen normalerweise in 48 Stunden. Kleine Serien (10-200 Stk.): 1-2 Wochen. Größere Serien: 2-4 Wochen je nach Komplexität. Brauchen Sie es dringend? Rufen Sie uns an — wir tun alles, um es funktionieren zu lassen.</span></p></div>
      </div>
      <div class="fi">
        <button class="fq" onclick="tog(this)">
          <span data-lang="cs" class="on">Mohu si nejdřív objednat vzorek?</span><span data-lang="sk">Môžem si najskôr objednať vzorku?</span><span data-lang="en">Can I order a sample first?</span><span data-lang="de">Kann ich zuerst ein Muster bestellen?</span>
          <svg class="fqicon" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="9" y1="2" x2="9" y2="16"/><line x1="2" y1="9" x2="16" y2="9"/></svg>
        </button>
        <div class="fa"><p><span data-lang="cs" class="on">Ano — a u větších zakázek to sami doporučujeme. Vzorek vám umožní ověřit materiál, rozměry i povrchovou úpravu ještě před schválením série. Je to nejlepší způsob, jak předejít zklamání na obou stranách.</span><span data-lang="sk">Áno — a pri väčších zákazkách to sami odporúčame. Vzorka vám umožní overiť materiál, rozmery aj povrchovú úpravu ešte pred schválením série. Je to najlepší spôsob, ako predísť sklamaniu na oboch stranách.</span><span data-lang="en">Yes — and we recommend it for larger orders. A sample lets you verify the material, size, and finish before approving the series. It's the best way to avoid disappointment on both sides.</span><span data-lang="de">Ja — und wir empfehlen es für größere Bestellungen. Ein Muster lässt Sie Material, Größe und Oberflächenbehandlung überprüfen, bevor Sie die Serie genehmigen. Es ist die beste Methode, um Enttäuschungen auf beiden Seiten zu vermeiden.</span></p></div>
      </div>
      <div class="fi">
        <button class="fq" onclick="tog(this)">
          <span data-lang="cs" class="on">Dostanu cenu předem, nebo mě překvapíte fakturou?</span><span data-lang="sk">Dostanem cenu vopred, alebo ma prekvapíte faktúrou?</span><span data-lang="en">Will I get a price upfront or will the invoice surprise me?</span><span data-lang="de">Bekomme ich einen Preis im Voraus oder überrascht mich die Rechnung?</span>
          <svg class="fqicon" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="9" y1="2" x2="9" y2="16"/><line x1="2" y1="9" x2="16" y2="9"/></svg>
        </button>
        <div class="fa"><p><span data-lang="cs" class="on">Vždy dostanete jasnou kalkulaci ještě před zahájením výroby. Žádné skryté poplatky, žádné záludné příplatky po dodání. A pokud se cokoliv v průběhu změní — první to víte vy.</span><span data-lang="sk">Vždy dostanete jasnú kalkuláciu ešte pred zahájením výroby. Žiadne skryté poplatky, žiadne záludné príplatky po dodaní. A ak sa čokoľvek v priebehu zmení — prví to viete vy.</span><span data-lang="en">You'll always get a clear quote before production starts. No hidden fees, no sneaky surcharges after delivery. And if anything changes along the way — you'll be the first to know.</span><span data-lang="de">Sie erhalten immer ein klares Angebot, bevor die Produktion beginnt. Keine versteckten Gebühren, keine hinterlistigen Zuschläge nach der Lieferung. Und wenn sich während des Prozesses etwas ändert — Sie sind die erste, die es erfährt.</span></p></div>
      </div>
    </div>
  </div>
</section>

<!-- ── CTA STRIP ── -->
<section id="cta">
  <div class="cta-in rv">
    <div>
      <h2 class="cta-title">
        <span data-lang="cs" class="on">Máte projekt? <em>Pošlete nám soubor.</em></span>
        <span data-lang="sk">Máte projekt? <em>Pošlite nám súbor.</em></span>
        <span data-lang="en">Have a project? <em>Send us a file.</em></span>
        <span data-lang="de">Haben Sie ein Projekt? <em>Schicken Sie uns eine Datei.</em></span>
      </h2>
      <p class="cta-sub"><span data-lang="cs" class="on">Odpovídáme do 24 hodin. Nabídka do 48 hodin. Žádné závazky, žádné složitosti.</span><span data-lang="sk">Odpovedáme do 24 hodín. Ponuka do 48 hodín. Žiadne záväzky, žiadne komplikácie.</span><span data-lang="en">We respond in 24 hours. Quote in 48 hours. No obligations, no complications.</span><span data-lang="de">Wir antworten innerhalb von 24 Stunden. Angebot innerhalb von 48 Stunden. Keine Verpflichtungen, keine Komplikationen.</span></p>
    </div>
    <a class="btn btn-white" href="#contact">
      <span data-lang="cs" class="on">Poptat zdarma →</span>
      <span data-lang="sk">Dopytovať zadarmo →</span>
      <span data-lang="en">Get a free quote →</span>
      <span data-lang="de">Kostenloses Angebot →</span>
    </a>
  </div>
</section>

<!-- ── CONTACT ── -->
<section id="contact">
  <div class="contact-in">
    <div class="rv">
      <p class="stag">Kontakt</p>
      <h2 class="ch2"><span data-lang="cs" class="on">Pojďme na to <em>společně.</em></span><span data-lang="sk">Poďme na to <em>spoločne.</em></span><span data-lang="en">Let's do this <em>together.</em></span><span data-lang="de">Lassen Sie es uns <em>gemeinsam angehen.</em></span></h2>
      <p class="contact-body"><span data-lang="cs" class="on">Napište nám nebo přiložte soubor — ozveme se do 24 hodin s konkrétní nabídkou. Přátelský rozhovor, žádné obchodní nátlaky. Prostě to dáme dohromady.</span><span data-lang="sk">Napíšte nám alebo priložte súbor — ozveme sa do 24 hodín s konkrétnou ponukou. Priateľský rozhovor, žiadne obchodné nátlaky. Jednoducho to dáme dokopy.</span><span data-lang="en">Write to us or attach a file — we'll get back to you in 24 hours with a specific offer. Friendly conversation, no sales pressure. Let's just make it happen.</span><span data-lang="de">Schreiben Sie uns oder fügen Sie eine Datei an — wir antworten Ihnen innerhalb von 24 Stunden mit einem spezifischen Angebot. Freundliches Gespräch, keine Verkaufsdrucke. Lassen Sie uns das einfach umsetzen.</span></p>
      <div class="contact-callout"><span data-lang="cs" class="on">Nevíte si rady? Klidně napište jen pár vět o tom, co potřebujete — my se zeptáme na zbytek.</span><span data-lang="sk">Neviete si rady? Pokojne napíšte len pár viet o tom, čo potrebujete — my sa spýtame na zvyšok.</span><span data-lang="en">Not sure what you need? Just write a few lines about what you're looking for — we'll ask for the rest.</span><span data-lang="de">Nicht sicher, was Sie brauchen? Schreiben Sie einfach ein paar Zeilen über das, was Sie suchen — wir fragen nach dem Rest.</span></div>
      <div class="cd"><p class="cd-lbl">Email</p><p class="cd-val"><a href="mailto:plant@wearetreed.com">plant@wearetreed.com</a></p></div>
      <div class="cd"><p class="cd-lbl"><span data-lang="cs" class="on">Telefon</span><span data-lang="sk">Telefón</span><span data-lang="en">Phone</span><span data-lang="de">Telefon</span></p><p class="cd-val"><a href="tel:+420601366516">+420 601 366 516</a></p></div>
      <div class="cd"><p class="cd-lbl"><span data-lang="cs" class="on">Provozní doba</span><span data-lang="sk">Prevádzkové hodiny</span><span data-lang="en">Hours</span><span data-lang="de">Öffnungszeiten</span></p><p class="cd-val"><span data-lang="cs" class="on">Po–Pá, 8:00–17:00</span><span data-lang="sk">Po–Pi, 8:00–17:00</span><span data-lang="en">Mon–Fri, 8:00–17:00</span><span data-lang="de">Mo–Fr, 8:00–17:00</span></p></div>
      <div class="cd"><p class="cd-lbl"><span data-lang="cs" class="on">Kde jsme</span><span data-lang="sk">Kde sme</span><span data-lang="en">Location</span><span data-lang="de">Ort</span></p><p class="cd-val">Šumperk, Česká republika</p></div>
    </div>
    <div class="rv d1">
      <div class="fg2">
        <div class="form-r"><label><span data-lang="cs" class="on">Jméno</span><span data-lang="sk">Meno</span><span data-lang="en">Name</span><span data-lang="de">Name</span></label><input type="text" placeholder="Jan Novák"></div>
        <div class="form-r"><label>Email</label><input type="email" placeholder="jan@firma.cz"></div>
      </div>
      <div class="form-r">
        <label><span data-lang="cs" class="on">O co jde? (volitelné)</span><span data-lang="sk">O čo ide? (voliteľné)</span><span data-lang="en">What's it about? (optional)</span><span data-lang="de">Worum geht es? (optional)</span></label>
        <select id="svc-sel">
          <option value="" disabled selected></option>
          <option id="s1">CNC frézování dřeva</option>
          <option id="s2">3D tisk</option>
          <option id="s3">Laserové gravírování / řezání</option>
          <option id="s4">Rapid prototyping</option>
          <option id="s5">Více technologií najednou</option>
          <option id="s6">Nevím — poraďte mi</option>
        </select>
      </div>
      <div class="form-r">
        <label><span data-lang="cs" class="on">Řekněte nám víc</span><span data-lang="sk">Povedzte nám viac</span><span data-lang="en">Tell us more</span><span data-lang="de">Erzählen Sie uns mehr</span></label>
        <textarea id="msg" placeholder="Popište projekt, materiál, rozměry, termín... nebo prostě napište, co potřebujete. Nic nemusí být dokonalé — zbytek dořešíme spolu."></textarea>
      </div>
      <button class="fsub" id="fsub">
        <span data-lang="cs" class="on" id="fcs">Odeslat poptávku →</span>
        <span data-lang="sk" id="fsk">Odoslať dopyt →</span>
        <span data-lang="en">Send inquiry →</span>
        <span data-lang="de">Anfrage senden →</span>
      </button>
      <p class="form-note"><span data-lang="cs" class="on">Odpovídáme do 24 hodin. Žádné závazky.</span><span data-lang="sk">Odpovedáme do 24 hodín. Žiadne záväzky.</span><span data-lang="en">We respond in 24 hours. No obligations.</span><span data-lang="de">Wir antworten innerhalb von 24 Stunden. Keine Verpflichtungen.</span></p>
      <div class="form-or"><span data-lang="cs" class="on">nebo nám napište přímo</span><span data-lang="sk">alebo nám napíšte priamo</span><span data-lang="en">or write us directly</span><span data-lang="de">oder schreiben Sie uns direkt</span></div>
      <p style="text-align:center;font-size:.87rem"><a href="mailto:plant@wearetreed.com" style="color:var(--accent);text-decoration:none;font-weight:500">plant@wearetreed.com</a></p>
    </div>
  </div>
</section>

<!-- ── FOOTER ── -->
<footer>
  <span class="fl">Forma<b>.</b></span>
  <ul class="flinks">
    <li><a href="#services"><span data-lang="cs" class="on">Služby</span><span data-lang="sk">Služby</span><span data-lang="en">Services</span><span data-lang="de">Leistungen</span></a></li>
    <li><a href="#gallery"><span data-lang="cs" class="on">Ukázky</span><span data-lang="sk">Ukážky</span><span data-lang="en">Showcase</span><span data-lang="de">Galerie</span></a></li>
    <li><a href="#about"><span data-lang="cs" class="on">O nás</span><span data-lang="sk">O nás</span><span data-lang="en">About us</span><span data-lang="de">Über uns</span></a></li>
    <li><a href="#faq">FAQ</a></li>
    <li><a href="#contact">Kontakt</a></li>
  </ul>
  <span class="fcopy">© 2026 Forma Studio · Šumperk · CNC · 3D · Laser</span>
</footer>

<script>
// ── LANG ──
let L='cs';
const TR={
  s1:{cs:'CNC frézování dřeva',sk:'CNC frézovanie dreva',en:'CNC milling',de:'CNC-Fräsen'},
  s2:{cs:'3D tisk',sk:'3D tlač',en:'3D printing',de:'3D-Druck'},
  s3:{cs:'Laserové gravírování / řezání',sk:'Laserové gravírovanie / rezanie',en:'Laser engraving / cutting',de:'Lasergravur / Schneiden'},
  s4:{cs:'Rapid prototyping',sk:'Rapid prototyping',en:'Rapid prototyping',de:'Schnellprototyping'},
  s5:{cs:'Více technologií najednou',sk:'Viac technológií naraz',en:'Combining technologies',de:'Mehrere Technologien auf einmal'},
  s6:{cs:'Nevím — poraďte mi',sk:'Neviem — poraďte mi',en:'Not sure — advise me',de:'Nicht sicher — beraten Sie mich'},
};
function setL(l){
  L=l;
  document.documentElement.lang=l;
  document.querySelectorAll('.lbtn').forEach(b=>b.classList.remove('on'));
  document.querySelector(`.lbtn[onclick="setL('${l}')"]`).classList.add('on');
  document.querySelectorAll('[data-lang]').forEach(el=>el.classList.toggle('on',el.dataset.lang===l));
  Object.entries(TR).forEach(([id,t])=>{const el=document.getElementById(id);if(el)el.textContent=t[l];});
  const ta=document.getElementById('msg');
  if(ta)ta.placeholder=
        l==='sk'?'Opíšte projekt, materiál, rozmery, termín... alebo jednoducho napíšte, čo potrebujete. Nič nemusí byť dokonalé — zvyšok doriešime spolu.'
        :l==='en'?'Describe the project, material, dimensions, deadline... or just write what you need. It doesn't have to be perfect — we'll figure out the rest together.'
        :l==='de'?'Beschreiben Sie das Projekt, Material, Abmessungen, Frist... oder schreiben Sie einfach, was Sie brauchen. Es muss nicht perfekt sein — wir lösen den Rest gemeinsam.'
        :'Popište projekt, materiál, rozměry, termín... nebo prostě napište, co potřebujete. Nic nemusí být dokonalé — zbytek dořešíme spolu.';
}
// ── FAQ ──
function tog(btn){
  const fi=btn.closest('.fi');
  const was=fi.classList.contains('open');
  document.querySelectorAll('.fi.open').forEach(f=>f.classList.remove('open'));
  if(!was)fi.classList.add('open');
}
// ── REVEAL ──
const obs=new IntersectionObserver(es=>{
  es.forEach(e=>{if(e.isIntersecting){e.target.classList.add('in');obs.unobserve(e.target);}});
},{threshold:0.05,rootMargin:'0px 0px -20px 0px'});
document.querySelectorAll('.rv').forEach(el=>obs.observe(el));
// ── FORM ──
document.getElementById('fsub').addEventListener('click',function(){
  const fields=document.querySelectorAll('#contact input[type=text],#contact input[type=email],#contact textarea');
  let ok=true;
  fields.forEach(f=>{if(!f.value.trim())ok=false;});
  const cs=document.getElementById('fcs'),sk=document.getElementById('fsk');
  if(ok){
    cs.textContent='Odesláno! Ozveme se do 24 h ✓';
        sk.textContent='Odoslané! Ozveme sa do 24 h ✓';
        const en=document.getElementById('fen'),de=document.getElementById('fde');
        if(en)en.textContent='Sent! We'll be in touch within 24h ✓';
        if(de)de.textContent='Gesendet! Wir melden uns in 24h ✓';
    this.style.background='#2a5a2a';
    setTimeout(()=>{cs.textContent='Odeslat poptávku →';
        sk.textContent='Odoslať dopyt →';
        if(en)en.textContent='Send request →';
        if(de)de.textContent='Anfrage senden →';this.style.background='';},4000);
  }else{
    cs.textContent='Vyplňte jméno, e-mail a zprávu';
        sk.textContent='Vyplňte meno, e-mail a správu';
        if(en)en.textContent='Please fill in name, email and message';
        if(de)de.textContent='Bitte füllen Sie Name, E-Mail und Nachricht aus';
    this.style.background='#7a2020';
    setTimeout(()=>{cs.textContent='Odeslat poptávku →';
        sk.textContent='Odoslať dopyt →';
        if(en)en.textContent='Send request →';
        if(de)de.textContent='Anfrage senden →';this.style.background='';},2800);
  }
});

/* Lightbox */
const lbOverlay=document.createElement('div');
lbOverlay.className='lb-overlay';
lbOverlay.innerHTML='<button class="lb-close">&times;</button><button class="lb-nav lb-prev">&#8249;</button><button class="lb-nav lb-next">&#8250;</button><img src="" alt=""><span class="lb-counter"></span>';
document.body.appendChild(lbOverlay);
const lbImg=lbOverlay.querySelector('img');
const lbClose=lbOverlay.querySelector('.lb-close');
const lbPrev=lbOverlay.querySelector('.lb-prev');
const lbNext=lbOverlay.querySelector('.lb-next');
const lbCounter=lbOverlay.querySelector('.lb-counter');
const lbAll=[...document.querySelectorAll('.gi img, .fp-photo img')];
let lbIdx=0;
function showLb(i){lbIdx=i;lbImg.src=lbAll[i].src;lbCounter.textContent=(i+1)+' / '+lbAll.length;}
lbAll.forEach((img,i)=>{
  img.style.cursor='zoom-in';
  img.addEventListener('click',()=>{
    showLb(i);
    lbOverlay.classList.add('active');
    document.body.style.overflow='hidden';
  });
});
function closeLb(){lbOverlay.classList.remove('active');document.body.style.overflow='';}
function navLb(dir){showLb((lbIdx+dir+lbAll.length)%lbAll.length);}
lbPrev.addEventListener('click',e=>{e.stopPropagation();navLb(-1);});
lbNext.addEventListener('click',e=>{e.stopPropagation();navLb(1);});
lbImg.addEventListener('click',e=>{e.stopPropagation();});
lbOverlay.addEventListener('click',closeLb);
lbClose.addEventListener('click',closeLb);
document.addEventListener('keydown',e=>{
  if(e.key==='Escape')closeLb();
  if(e.key==='ArrowLeft')navLb(-1);
  if(e.key==='ArrowRight')navLb(1);
});
</script>
</body>
</html>